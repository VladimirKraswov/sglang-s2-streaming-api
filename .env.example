API_PORT=7782
DATA_DIR=./data
SGLANG_OMNI_IMAGE=lmsysorg/sglang:nightly-dev-cu13-20260414-c456cba7

CUDA_VISIBLE_DEVICES=0
HF_ENDPOINT=https://huggingface.co
PYTORCH_ALLOC_CONF=expandable_segments:True
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
FLASHINFER_DISABLE_VERSION_CHECK=1
TORCHINDUCTOR_MAX_AUTOTUNE=1
SHM_SIZE=32g
HEALTHCHECK_START_PERIOD=2400s

S2_MODEL_PATH=/data/checkpoints/s2-pro
S2_MODEL_NAME=fishaudio-s2-streaming
S2_CONFIG_PATH=/opt/sglang-omni/examples/configs/s2pro_tts.yaml
S2_REFERENCE_ROOT=/data/references

S2_MANAGE_BACKEND=true
S2_BACKEND_URL=http://127.0.0.1:8092
S2_BACKEND_HOST=127.0.0.1
S2_BACKEND_PORT=8092
S2_BACKEND_LOG_LEVEL=info
SGL_OMNI_BIN=sgl-omni
S2_STARTUP_TIMEOUT=2400
S2_REQUEST_TIMEOUT=3600
S2_CONNECT_TIMEOUT=30

# TTFA-first experimental profile
S2_EXTRA_ARGS=-

S2_WARMUP=true
S2_WARMUP_REQUESTS=2
S2_WARMUP_TEXT=Раз два три четыре пять. Шесть семь восемь девять десять.
S2_WARMUP_MAX_NEW_TOKENS=32

S2_TARGET_FIRST_BYTE_MS=200
S2_EARLY_WAV_HEADER=true
S2_TEXT_CHUNKING=true
S2_FIRST_CHUNK_WORDS=3
S2_CHUNK_WORDS=5
S2_JOIN_SILENCE_MS=0
S2_STREAM_SAMPLE_RATE=44100
S2_STREAM_CHANNELS=1
S2_STREAM_BITS_PER_SAMPLE=16

S2_TEMPERATURE=0.8
S2_TOP_P=0.8
S2_TOP_K=30
S2_REPETITION_PENALTY=1.1
S2_SEED=
S2_MAX_NEW_TOKENS=1024
S2_SPEED=1.0